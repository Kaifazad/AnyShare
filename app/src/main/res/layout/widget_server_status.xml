<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- Status indicator -->
    <View
        android:id="@+id/status_indicator"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:background="@drawable/widget_status_dot_offline" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LocalShare"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#E0E0E0" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Server Offline"
            android:textSize="12sp"
            android:textColor="#A0A0A0" />
    </LinearLayout>

    <!-- Toggle button -->
    <ImageButton
        android:id="@+id/toggle_button"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/widget_toggle_play"
        android:background="@drawable/widget_button_bg"
        android:contentDescription="Toggle server"
        android:scaleType="centerInside"
        android:padding="12dp" />

</LinearLayout>
