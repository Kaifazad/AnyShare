<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="#FF1A1A2E"
    android:paddingStart="14dp"
    android:paddingEnd="10dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- Left: Circle with dot -->
    <ImageView
        android:id="@+id/status_indicator"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/widget_status_circle_offline"
        android:scaleType="centerInside" />

    <!-- Middle: Text -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LocalShare"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Offline"
            android:textSize="12sp"
            android:textColor="#888888"
            android:fontFamily="monospace"
            android:singleLine="true"
            android:ellipsize="end"
            android:paddingTop="2dp" />
    </LinearLayout>

    <!-- Right: Circular button -->
    <ImageView
        android:id="@+id/toggle_button"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/widget_toggle_play"
        android:background="@drawable/widget_button_bg"
        android:contentDescription="Toggle server"
        android:scaleType="centerInside"
        android:padding="12dp" />

</LinearLayout>
